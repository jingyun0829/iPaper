# ── 前端 (Vite 读取，VITE_ 前缀必须有) ──────────────────────────
# 在 Supabase Dashboard → Project Settings → API 里找到

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...（anon public key）

# ── 后端 Python 脚本用 ────────────────────────────────────────────
# 本地运行时放在这里；GitHub Actions 里在 Secrets 设置

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...（service_role key，有写入权限）
